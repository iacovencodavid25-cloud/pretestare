            {
                SqlCommand cmd = new SqlCommand("sp_adauga_angajat", con);
                cmd.CommandType = CommandType.StoredProcedure;

                cmd.Parameters.AddWithValue("@nume_prenume", txtNume.Text);
                cmd.Parameters.AddWithValue("@data_nasterii", dtpDataNasterii.Value);
                cmd.Parameters.AddWithValue("@adresa", txtAdresa.Text);
                cmd.Parameters.AddWithValue("@telefon", txtTelefon.Text);
                cmd.Parameters.AddWithValue("@stagiu", Convert.ToInt32(txtStagiu.Text));
                cmd.Parameters.AddWithValue("@nr_departament", Convert.ToInt32(txtNrDepartament.Text));

                con.Open();
                cmd.ExecuteNonQuery();
                con.Close();

                MessageBox.Show("Angajat adăugat!");
                AfiseazaAngajati();
            }
        }

